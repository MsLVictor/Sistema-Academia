@{
    Layout = null;
    var nome = Context.Session.GetString("UsuarioNome") ?? "Aluno";
}
<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Meu Painel · FitManager</title>
  <style>
    :root {
      --fundo:          oklch(99% 0.002 240);
      --superficie:     oklch(100% 0 0);
      --texto:          oklch(18% 0.012 250);
      --texto-muted:    oklch(54% 0.012 250);
      --borda:          oklch(92% 0.005 250);
      --destaque:       oklch(82% 0.18 145);
      --destaque-suave: color-mix(in oklch, var(--destaque) 14%, transparent);
      --fonte-titulo: 'Iowan Old Style', 'Charter', Georgia, serif;
      --fonte-corpo:  -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;
      --raio: 10px; --raio-lg: 16px;
      --gap-md: 20px; --gap-lg: 32px;
      --largura-sidebar: 260px;
    }
    *, *::before, *::after { box-sizing: border-box; }
    body { margin: 0; background: var(--fundo); color: var(--texto); font-family: var(--fonte-corpo); display: flex; min-height: 100vh; }

    .sidebar { width: var(--largura-sidebar); background: var(--superficie); border-right: 1px solid var(--borda); padding: 24px; display: flex; flex-direction: column; position: fixed; height: 100vh; }
    .logo { font-family: var(--fonte-titulo); font-size: 20px; font-weight: 600; margin-bottom: 8px; }
    .logo-sub { font-size: 12px; color: var(--texto-muted); margin-bottom: 40px; }
    .nav { list-style: none; padding: 0; margin: 0; flex-grow: 1; }
    .nav-item { margin-bottom: 6px; }
    .nav-link { display: flex; align-items: center; gap: 12px; padding: 10px 14px; border-radius: var(--raio); color: var(--texto-muted); text-decoration: none; font-size: 14px; transition: background 0.2s, color 0.2s; }
    .nav-link:hover { background: var(--destaque-suave); color: var(--texto); }

    .principal { margin-left: var(--largura-sidebar); flex-grow: 1; padding: 40px; max-width: 1000px; }
    .titulo-pagina { font-family: var(--fonte-titulo); font-size: 28px; margin: 0 0 8px; }
    .subtitulo { color: var(--texto-muted); font-size: 14px; margin: 0 0 40px; }

    .grade { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--gap-md); }
    .cartao { background: var(--superficie); border: 1px solid var(--borda); border-radius: var(--raio-lg); padding: 28px; }
    .cartao-icone { font-size: 28px; margin-bottom: 16px; }
    .cartao h3 { font-family: var(--fonte-titulo); font-size: 16px; margin: 0 0 8px; }
    .cartao p { font-size: 13px; color: var(--texto-muted); margin: 0 0 20px; line-height: 1.5; }
    .btn { display: inline-flex; align-items: center; gap: 6px; padding: 8px 16px; border-radius: var(--raio); border: 1px solid var(--borda); background: var(--superficie); color: var(--texto); font-size: 13px; font-weight: 600; cursor: pointer; text-decoration: none; }
    .btn:hover { background: var(--fundo); }
    .btn-primario { background: var(--destaque); border-color: var(--destaque); }

    .badge-em-breve { display: inline-block; padding: 2px 8px; background: var(--fundo); border: 1px solid var(--borda); border-radius: 999px; font-size: 11px; color: var(--texto-muted); }
  </style>
</head>
<body>

  <aside class="sidebar">
    <div class="logo">FitManager</div>
    <div class="logo-sub">Área do Aluno</div>
    <ul class="nav">
      <li class="nav-item">
        <a href="#" class="nav-link">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="4" width="22" height="16" rx="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>
          Mensalidades
        </a>
      </li>
      <li class="nav-item">
        <a href="#" class="nav-link">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
          Meus Treinos
        </a>
      </li>
      <li class="nav-item">
        <a href="#" class="nav-link">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          Minha Matrícula
        </a>
      </li>
    </ul>
    <div style="margin-top: auto;">
      <div style="font-size: 13px; font-weight: 600; padding: 10px 14px; margin-bottom: 4px;">@nome</div>
      <a asp-controller="Login" asp-action="Sair" class="nav-link">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
          <polyline points="16 17 21 12 16 7"/>
          <line x1="21" y1="12" x2="9" y2="12"/>
        </svg>
        Sair
      </a>
    </div>
  </aside>

  <main class="principal">
    <h1 class="titulo-pagina">Bem-vindo, @nome</h1>
    <p class="subtitulo">Acompanhe sua jornada na academia.</p>

    <div class="grade">
      <div class="cartao">
        <div class="cartao-icone">💳</div>
        <h3>Mensalidades</h3>
        <p>Acompanhe seus pagamentos, datas de vencimento e histórico financeiro.</p>
        <span class="badge-em-breve">Em breve</span>
      </div>
      <div class="cartao">
        <div class="cartao-icone">💪</div>
        <h3>Meus Treinos</h3>
        <p>Visualize as fichas de treino cadastradas pelo seu instrutor.</p>
        <span class="badge-em-breve">Em breve</span>
      </div>
      <div class="cartao">
        <div class="cartao-icone">📅</div>
        <h3>Minha Matrícula</h3>
        <p>Veja a modalidade, plano e validade da sua matrícula atual.</p>
        <span class="badge-em-breve">Em breve</span>
      </div>
    </div>
  </main>

</body>
</html>
