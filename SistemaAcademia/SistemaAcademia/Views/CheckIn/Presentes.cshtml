@{
    Layout = null;
    var presentes = ViewBag.Presentes as IEnumerable<SistemaAcademia.Models.CheckInPresencaViewModel>
                    ?? Enumerable.Empty<SistemaAcademia.Models.CheckInPresencaViewModel>();
}
<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Na Academia · FitManager</title>
  <style>
    :root {
      --fundo: oklch(99% 0.002 240); --superficie: oklch(100% 0 0);
      --texto: oklch(18% 0.012 250); --texto-muted: oklch(54% 0.012 250);
      --borda: oklch(92% 0.005 250); --destaque: oklch(82% 0.18 145);
      --destaque-suave: color-mix(in oklch, var(--destaque) 14%, transparent);
      --fonte-corpo: -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;
      --fonte-mono: ui-monospace, 'JetBrains Mono', monospace;
      --raio: 10px; --raio-lg: 16px;
    }
    *, *::before, *::after { box-sizing: border-box; }
    body { margin: 0; background: var(--fundo); color: var(--texto); font-family: var(--fonte-corpo); }
    .topbar { background: var(--superficie); border-bottom: 1px solid var(--borda); padding: 14px 40px; display: flex; align-items: center; gap: 16px; }
    .topbar-logo { font-family: 'Iowan Old Style', Georgia, serif; font-size: 18px; font-weight: 600; }
    .topbar-sep { color: var(--borda); }
    .topbar-titulo { font-size: 15px; font-weight: 600; flex-grow: 1; }
    .topbar-usuario { font-size: 13px; color: var(--texto-muted); }
    .topbar-voltar { font-size: 13px; color: var(--texto-muted); text-decoration: none; }
    .topbar-voltar:hover { color: var(--texto); }
    .conteudo { max-width: 800px; margin: 0 auto; padding: 40px; }
    .cabecalho { display: flex; align-items: center; justify-content: space-between; margin-bottom: 24px; }
    .titulo { font-size: 20px; font-weight: 700; margin: 0; }
    .contador { font-size: 14px; color: var(--texto-muted); }
    .cartao { background: var(--superficie); border: 1px solid var(--borda); border-radius: var(--raio-lg); overflow: hidden; }
    .item { display: flex; align-items: center; padding: 16px 20px; border-bottom: 1px solid var(--borda); gap: 16px; }
    .item:last-child { border-bottom: none; }
    .item:hover { background: var(--fundo); }
    .item-nome { font-weight: 600; font-size: 15px; flex: 1; }
    .item-hora { font-family: var(--fonte-mono); font-size: 13px; color: var(--texto-muted); }
    .item-rec  { font-size: 12px; color: var(--texto-muted); min-width: 140px; text-align: right; }
    .btn { display: inline-flex; align-items: center; padding: 6px 14px; border-radius: var(--raio); border: 1px solid oklch(85% 0.08 15); background: var(--superficie); color: oklch(35% 0.15 15); font-size: 12px; font-weight: 600; cursor: pointer; font-family: inherit; }
    .btn:hover { background: oklch(97% 0.02 15); }
    .btn-scanner { display: inline-flex; align-items: center; gap: 6px; padding: 9px 16px; border-radius: var(--raio); border: 1px solid var(--borda); background: var(--superficie); color: var(--texto); font-size: 13px; font-weight: 600; text-decoration: none; }
    .btn-scanner:hover { background: var(--fundo); }
    .vazio { text-align: center; padding: 60px 20px; color: var(--texto-muted); font-size: 15px; }
    .pulso { display: inline-block; width: 8px; height: 8px; border-radius: 50%; background: var(--destaque); animation: pulso 2s ease-in-out infinite; }
    @@keyframes pulso { 0%, 100% { opacity: 1; } 50% { opacity: 0.3; } }
  </style>
</head>
<body>

<header class="topbar">
  <a class="topbar-logo" asp-controller="Home" asp-action="Index" style="text-decoration:none;color:inherit;">FitManager</a>
  <span class="topbar-sep">·</span>
  <span class="topbar-titulo">Na Academia agora</span>
  <span class="topbar-usuario">@ViewData["Nome"]</span>
  <a asp-controller="CheckIn" asp-action="Scanner" class="topbar-voltar">← Scanner</a>
</header>

<main class="conteudo">

  <div class="cabecalho">
    <div>
      <h1 class="titulo"><span class="pulso"></span> Presentes hoje</h1>
      <p class="contador" style="margin-top: 4px;">@presentes.Count() aluno(s) na academia</p>
    </div>
    <a asp-controller="CheckIn" asp-action="Scanner" class="btn-scanner">Registrar entrada</a>
  </div>

  <div class="cartao">
    @if (!presentes.Any())
    {
      <div class="vazio">Nenhum aluno registrado ainda hoje.</div>
    }
    else
    {
      @foreach (var p in presentes)
      {
        <div class="item">
          <div class="item-nome">@p.NomeCliente</div>
          <div class="item-hora">Entrou @p.DataHoraEntrada.ToString("HH:mm")</div>
          <div class="item-rec">via @p.NomeRecepcionista</div>
          <form method="post" asp-action="Saida">
            <input type="hidden" name="id" value="@p.IdCheckIn" />
            <button type="submit" class="btn">Registrar saída</button>
          </form>
        </div>
      }
    }
  </div>

</main>

</body>
</html>
