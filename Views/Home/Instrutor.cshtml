@{
    ViewData["Title"] = "Painel Instrutor";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="fw-bold mb-0"> Painel do Instrutor</h2>
        <p class="text-muted mb-0">Bem-vindo, @ViewData["Nome"]!</p>
    </div>
</div>

<div class="row g-3">
    <div class="col-md-4">
        <div class="card border-0 shadow-sm text-center p-3">
            <div style="font-size:2rem"></div>
            <h6 class="mt-2 fw-bold">Treinos</h6>
            <p class="text-muted small">Cadastrar treinos diários para os alunos</p>
            <a href="#" class="btn btn-sm btn-warning">Acessar</a>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm text-center p-3">
            <div style="font-size:2rem"></div>
            <h6 class="mt-2 fw-bold">Meus Alunos</h6>
            <p class="text-muted small">Visualizar alunos vinculados</p>
            <a href="#" class="btn btn-sm btn-warning">Acessar</a>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm text-center p-3">
            <div style="font-size:2rem"></div>
            <h6 class="mt-2">Evolução</h6>
            <p class="text-muted small">Acompanhar progresso dos alunos</p>
            <a href="#" class="btn btn-sm btn-warning">Acessar</a>
        </div>
    </div>
</div>
