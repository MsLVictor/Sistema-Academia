@{
    ViewData["Title"] = "Painel Administrador";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="fw-bold mb-0">Painel do Administrador</h2>
        <p class="text-muted mb-0">Bem-vindo, @ViewData["Nome"]!</p>
    </div>
</div>

<div class="row g-3">
    <div class="col-md-3">
        <div class="card border-0 shadow-sm text-center p-3">
            <h6 class="mt-2 fw-bold">Usuários</h6>
            <p class="text-muted small">Gerenciar cadastros e cargos</p>
            <a href="#" class="btn btn-sm btn-primary">Acessar</a>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm text-center p-3">
            <h6 class="mt-2 fw-bold">Pagamentos</h6>
            <p class="text-muted small">Visualizar todas as mensalidades</p>
            <a href="#" class="btn btn-sm btn-primary">Acessar</a>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm text-center p-3">
            <h6 class="mt-2 fw-bold">Treinos</h6>
            <p class="text-muted small">Acompanhar treinos cadastrados</p>
            <a href="#" class="btn btn-sm btn-primary">Acessar</a>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm text-center p-3">
            <h6 class="mt-2 fw-bold">Relatórios</h6>
            <p class="text-muted small">Dados e métricas da academia</p>
            <a href="#" class="btn btn-sm btn-primary">Acessar</a>
        </div>
    </div>
</div>
